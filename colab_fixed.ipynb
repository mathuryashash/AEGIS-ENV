   "source": [
    "# === CELL 9: Save Model ===\n",
    "model.save_pretrained(\"aegis-trained-model\")\n",
    "tokenizer.save_pretrained(\"aegis-trained-model\")\n",
    "print(\"✓ Model saved locally\")\n",
    "\n",
    "# Push to HF Hub\n",
    "api = HfApi()\n",
    "api.upload_folder(\n",
    "    folder_path=\"aegis-trained-model\",\n",
    "    repo_id=\"YOUR_USERNAME/aegis-colab-trained\",\n",
    "    repo_type=\"model\",\n",
    "    commit_message=\"Trained on Colab\",\n",
    "    token=HF_TOKEN,\n",
    ")\n",
    "print(\"✓ Model pushed to Hugging Face!\")"
   ]
  }
